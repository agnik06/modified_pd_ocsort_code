<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CameraActivity">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:background="@color/activity_background">

        <RelativeLayout
            android:layout_width="@dimen/camera_view_width"
            android:layout_height="@dimen/camera_view_height">
            <TextureView
                android:id="@+id/texture_view_camera"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true" />
            <ImageView
                android:id="@+id/mask_view_camera"
                android:alpha="1"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/controls_camera"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/activity_background">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/camera_display_text"
                android:textColor="#E9E9E9"
                android:textAlignment="center"
                android:layout_marginTop="10dp"
                android:text="Double tap to start/stop" />

            <vizinsight.atl.videoautofocus.ui.ToggleImageButton
                android:id="@+id/process_button"
                android:layout_height="wrap_content"
                android:layout_margin="0dp"
                android:layout_width="match_parent"
                android:layout_gravity="center"
                android:scaleType="fitCenter"
                android:src="@drawable/click"
                android:background="@color/activity_background"
                android:scaleX="0.5"
                android:scaleY="0.5" />

        </LinearLayout>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
