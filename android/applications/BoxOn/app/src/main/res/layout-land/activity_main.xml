<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="100dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent">

        <vizinsight.atl.videoautofocus.ui.ToggleImageButton
            android:id="@+id/camera_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="0dp"
            android:src="@drawable/camera_select"
            android:background="@color/ic_launcher_background"
            android:scaleX="0.5"
            android:scaleY="0.5" />

        <vizinsight.atl.videoautofocus.ui.ToggleImageButton
            android:id="@+id/image_select_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="0dp"
            android:visibility="invisible"
            android:src="@drawable/image_select"
            android:background="@color/ic_launcher_background"
            android:scaleX="0.5"
            android:scaleY="0.5"/>

        <vizinsight.atl.videoautofocus.ui.ToggleImageButton
            android:id="@+id/folder_select_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="0dp"

            android:src="@drawable/folder_select"
            android:background="@color/ic_launcher_background"
            android:scaleX="0.56"
            android:scaleY="0.65"/>

        <vizinsight.atl.videoautofocus.ui.ToggleImageButton
            android:id="@+id/scene_select_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="0dp"
            android:visibility="invisible"
            android:src="@drawable/scene_optimizer_pro"
            android:background="@color/ic_launcher_background"
            android:scaleX="0.44"
            android:scaleY="0.44"/>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>