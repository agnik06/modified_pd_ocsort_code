<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CameraActivity">
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/activity_background"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="@dimen/camera_view_width"
        android:layout_height="@dimen/camera_view_height">
        <TextureView
            android:id="@+id/texture_view_camera"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true" />

        <ImageView
            android:id="@+id/mask_view_camera"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0.5" />
    </RelativeLayout>

    <RelativeLayout
        android:layout_width="@dimen/camera_view_width"
        android:layout_height="@dimen/camera_view_height"
        android:layout_marginTop="30dp">
        <TextureView
            android:id="@+id/texture_view_camera1"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true" />

        <ImageView
            android:id="@+id/track_imageView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0.5" />
    </RelativeLayout>

